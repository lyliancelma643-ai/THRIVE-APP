# ─────────────────────────────────────────
# THRIVE APP — Variables d'environnement
# Copie ce fichier en .env.development, .env.staging, .env.production
# Ne JAMAIS commiter les fichiers .env réels
# ─────────────────────────────────────────

# App
NODE_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000

# Database (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
DATABASE_URL=postgresql://user:password@localhost:5432/thrive_dev

# Auth
JWT_SECRET=your_jwt_secret_minimum_32_chars
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Storage
S3_BUCKET=
S3_REGION=ca-central-1

# Notifications
EXPO_PUSH_TOKEN=
SENDGRID_API_KEY=

# RevenueCat (Mobile IAP)
REVENUECAT_API_KEY_IOS=
REVENUECAT_API_KEY_ANDROID=

# Web
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Mobile (Expo — variables embarquées dans le bundle : clés PUBLIQUES uniquement)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=
