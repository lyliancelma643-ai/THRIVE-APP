{
  "name": "@thrive/shared",
  "version": "1.0.0",
  "description": "Shared types, enums, hooks and utilities for THRIVE monorepo",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
